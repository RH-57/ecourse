// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  mentor
  student
}

enum UserStatus {
  active
  inactive
  blocked
}

enum CourseStatus {
  draft
  published
  archived
}

enum CourseLevel {
  beginner
  intermediate
  advanced
}

model User {
  id        String     @id @default(cuid())
  name      String?
  email     String     @unique
  password  String?
  status    UserStatus @default(active)
  role      Role       @default(student)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?

  sessions       Session[]
  coursesCreated Course[]

  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  prefix      String  @unique @db.VarChar(5)
  description String? @db.Text
  image       String?

  metaTitle       String?
  metaDescription String? @db.Text

  status    String    @default("active")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  courses Course[]

  @@index([slug])
  @@index([status])
  @@map("categories")
}

model Course {
  id              String  @id @default(cuid())
  code            String  @unique // Contoh: SK001
  title           String
  slug            String  @unique
  excerpt         String? @db.VarChar(255)
  description     String? @db.Text
  thumbnail       String?
  videoPreviewUrl String?

  price         Decimal      @default(0.00) @db.Decimal(12, 2)
  discountPrice Decimal?     @db.Decimal(12, 2)
  level         CourseLevel  @default(beginner)
  status        CourseStatus @default(draft)

  // SEO Metadata
  metaTitle       String?
  metaDescription String? @db.Text
  ogImage         String?

  // Relations
  categoryId   String
  category     Category @relation(fields: [categoryId], references: [id])
  instructorId String
  instructor   User     @relation(fields: [instructorId], references: [id])
  modules      Module[]

  // Audit
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([slug])
  @@index([categoryId])
  @@index([instructorId])
  @@map("courses")
}

model Module {
  id    String @id @default(cuid())
  title String // Contoh: "Materi 1: Pondasi"
  order Int    @default(0) // Untuk mengurutkan folder daftar isi

  courseId String
  course   Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons  Lesson[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@map("modules")
}

model Lesson {
  id       String  @id @default(cuid())
  title    String
  slug     String  @unique
  videoUrl String
  duration Int? // Menit
  order    Int     @default(0) // Urutan materi di dalam modul
  isFree   Boolean @default(false) // Fitur preview materi gratis

  moduleId String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([moduleId])
  @@map("lessons")
}
